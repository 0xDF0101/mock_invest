# 이 파일을 복사해서 .env 로 사용하세요
# cp .env.example .env

DB_ROOT_PASSWORD=강한루트비밀번호
DB_USER=mock_invest_user
DB_PASSWORD=강한유저비밀번호

# 이메일 발송 (Gmail SMTP 예시)
# Gmail 앱 비밀번호 사용 권장: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# 이메일 링크에 사용될 서비스 베이스 URL
APP_BASE_URL=https://your-domain.com
